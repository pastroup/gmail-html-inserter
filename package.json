{
  "name": "gmail-html-inserter",
  "version": "1.0.0",
  "private": true,
  "description": "Chrome extension: compose HTML with live preview and insert it into a Gmail message.",
  "scripts": {
    "build": "esbuild editor-entry.js --bundle --format=iife --minify --outfile=vendor/editor.bundle.js",
    "watch": "esbuild editor-entry.js --bundle --format=iife --outfile=vendor/editor.bundle.js --watch",
    "package": "npm run build && bash scripts/package.sh"
  },
  "devDependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.6.0",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.34.0",
    "esbuild": "^0.24.0"
  }
}
